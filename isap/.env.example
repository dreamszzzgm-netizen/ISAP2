API_KEY=dev-secret
# === NVIDIA GPU / NGC ===
# Личный ключ из https://ngc.nvidia.com/setup → Generate Personal Key
# Используется для авторизации при скачивании образов из nvcr.io
NGC_API_KEY=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

# === Приложение ===
APP_ENV=development
APP_SECRET_KEY=generate-a-strong-random-key

# === База данных ===
DATABASE_URL=postgresql+asyncpg://isap_user:isap_password@localhost:5432/isap

# === LLM ===
# Вариант 1: Ollama (локально, для разработки)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Вариант 2: Gemini (облако, для продакшена)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-gemini-api-key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.5-flash

# === ChromaDB ===
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=isap_knowledge

# === RAG ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# === Генерация документов ===
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# === Геокодирование (Яндекс) ===
YANDEX_GEOCODER_API_KEY=your-yandex-api-key
