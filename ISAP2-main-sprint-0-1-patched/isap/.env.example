# === Приложение ===
APP_ENV=development
APP_SECRET_KEY=generate-a-strong-random-key

# === База данных ===
DATABASE_URL=postgresql+asyncpg://isap_user:isap_password@localhost:5432/isap

# === LLM ===
# Вариант 1: LM Studio (локально, OpenAI-compatible API)
# В LM Studio включите Local Server на порту 1234.
LLM_PROVIDER=lmstudio
LLM_FALLBACK_ENABLED=false
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=local-model
# Embeddings are configured separately from chat LLM.
EMBEDDING_PROVIDER=lmstudio
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100

# Вариант 2: Ollama (оставлен как альтернативный провайдер)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3:8b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Вариант 3: Gemini/OpenAI-compatible cloud API
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-gemini-api-key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-2.5-flash

# === ChromaDB ===
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=isap_knowledge

# === RAG ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# === Генерация документов ===
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# === Геокодирование (Яндекс) ===
YANDEX_GEOCODER_API_KEY=your-yandex-api-key
